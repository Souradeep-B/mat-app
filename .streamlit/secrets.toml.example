# ────────────────────────────────────────────────────────────────────────────
# MAT — Streamlit Cloud secrets template
# Copy this content into:  Streamlit Cloud → your app → Settings → Secrets
# (Do NOT commit the real secrets.toml — it is gitignored.)
# ────────────────────────────────────────────────────────────────────────────

# ── Needed for the FIRST deploy (demo-login mode) ───────────────────────────
AUTH_MODE     = "demo"                                   # "demo" now; switch to "google" in Stage 6
ADMIN_EMAIL   = "souradeep.bhattachar@capillarytech.com" # always seeded as Admin
COOKIE_SECRET = "CHANGE-ME-to-a-long-random-string"      # used to sign session cookies

# Supabase Postgres connection string (Project Settings → Database → URI).
# Replace [YOUR-PASSWORD] with your DB password.
DATABASE_URL  = "postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres"

# Gmail (for approval / report emails)
GMAIL_SENDER       = "souradeep.bhattacharjee@optum.com"
GMAIL_APP_PASSWORD = "your gmail app password"

# Optional — only if/when you connect Claude
# ANTHROPIC_API_KEY = "sk-ant-..."

# ── Add these in Stage 6, when you switch to real Google login ──────────────
# OAUTH_REDIRECT_URI = "https://mat-capillary.streamlit.app/"
# GOOGLE_CREDENTIALS_JSON = '''
# {paste the entire contents of the OAuth client JSON you downloaded from Google here}
# '''
